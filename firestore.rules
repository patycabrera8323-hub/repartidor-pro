rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        // Case 1: Merchant or Admin updating status (accepted, preparing, ready, completed)
        (request.resource.data.status in ['accepted', 'preparing', 'ready', 'completed', 'cancelled'] && 
         request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'updatedAt'])) ||
        
        // Case 2: Driver claiming the order (assigning driverId)
        (!resource.data.keys().contains('driverId') && 
         request.resource.data.driverId == request.auth.uid && 
         request.resource.data.status == resource.data.status &&
         request.resource.data.diff(resource.data).affectedKeys().hasAny(['driverId', 'acceptedAt'])) ||
        
        // Case 3: Driver updating their assigned order (ready -> on_way -> delivered)
        (resource.data.driverId == request.auth.uid && 
         request.resource.data.status in ['on_way', 'delivered', 'cancelled'] &&
         request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'deliveredAt', 'updatedAt']))
      );
    }

    // --- Drivers Collection ---
    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(driverId);
    }
  }
}

